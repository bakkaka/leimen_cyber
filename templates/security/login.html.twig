{% extends 'base.html.twig' %}

{% block title %}Connexion - Cyber Formation Maroc{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <i class="bi bi-shield-lock-fill display-1" style="color: #FF7F00;"></i>
                        <h2 class="mt-3 fw-bold">Connexion</h2>
                        <p class="text-muted">Accédez à vos formations</p>
                    </div>

                    {% if error %}
                        <div class="alert alert-danger rounded-3 mb-4" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            {{ error.messageKey|trans(error.messageData, 'security') }}
                        </div>
                    {% endif %}

                    <form method="post">
    <div class="mb-3">
        <label for="email" class="form-label fw-semibold">Email</label>
        <div class="input-group">
            <span class="input-group-text bg-light border-end-0">
                <i class="bi bi-envelope text-muted"></i>
            </span>
            <input type="email" 
                   name="email"           {# ← CECI EST CRUCIAL #}
                   id="email" 
                   value="{{ last_username }}" 
                   class="form-control border-start-0" 
                   placeholder="votre@email.com"
                   autocomplete="email" 
                   required 
                   autofocus>
        </div>
    </div>

    <div class="mb-3">
        <label for="password" class="form-label fw-semibold">Mot de passe</label>
        <div class="input-group">
            <span class="input-group-text bg-light border-end-0">
                <i class="bi bi-lock text-muted"></i>
            </span>
            <input type="password" 
                   name="password"        {# ← CECI EST CRUCIAL #}
                   id="password" 
                   class="form-control border-start-0" 
                   placeholder="••••••"
                   autocomplete="current-password" 
                   required>
        </div>
    </div>

    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

    <button type="submit" class="btn-cyber w-100 py-2">
        <i class="bi bi-box-arrow-in-right me-2"></i>Se connecter
    </button>
</form>

                    <hr class="my-4">

                    <div class="text-center">
                        <p class="mb-2">Pas encore de compte ?</p>
                        <a href="{{ path('app_register') }}" class="btn-cyber-outline w-100 py-2 mb-3">
                            <i class="bi bi-person-plus me-2"></i>Créer un compte gratuit
                        </a>
                        <div class="mt-3">
                            <a href="#" class="text-decoration-none small text-muted">
                                <i class="bi bi-question-circle me-1"></i>Mot de passe oublié ?
                            </a>
                        </div>
                    </div>

                    <div class="text-center mt-4">
                        <p class="small text-muted mb-0">
                            En vous connectant, vous acceptez nos 
                            <a href="#" class="text-decoration-none">Conditions d'utilisation</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Types d'accès -->
    <div class="row justify-content-center mt-5">
        <div class="col-md-8">
            <div class="bg-light rounded-4 p-4 text-center">
                <h5 class="mb-3">🎓 Accès selon votre abonnement</h5>
                <div class="row">
                    <div class="col-md-4">
                        <div class="small">
                            <i class="bi bi-star-fill text-warning"></i>
                            <strong class="d-block mt-1">Débutant</strong>
                            <span class="text-muted">Cours fondamentaux</span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="small">
                            <i class="bi bi-star-half text-warning"></i>
                            <strong class="d-block mt-1">Intermédiaire</strong>
                            <span class="text-muted">+ Hacking éthique</span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="small">
                            <i class="bi bi-gem text-warning"></i>
                            <strong class="d-block mt-1">Avancé</strong>
                            <span class="text-muted">Expert complet</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
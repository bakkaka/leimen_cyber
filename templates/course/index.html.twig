{% extends 'base.html.twig' %}

{% block title %}Formations Cybersécurité - Cours pratiques au Maroc{% endblock %}

{% block body %}
<div class="hero-section">
    <div class="container text-center">
        <div class="hero-badge">🔥 Formations certifiantes 🔥</div>
        <h1 class="hero-title">Maîtrisez la Cybersécurité</h1>
        <p class="lead text-white-50 mb-4">
            +50 étudiants formés · Certificat offert · Support 24/7
        </p>
        <div class="d-flex gap-3 justify-content-center">
            <a href="#formations" class="btn-cyber btn-lg">📚 Voir les formations</a>
            <a href="#extraits" class="btn-cyber-outline btn-lg">▶️ Extraits gratuits</a>
        </div>
    </div>
</div>

<div class="container py-5" id="formations">
    <h2 class="text-center mb-5" data-aos="fade-up">📚 Nos formations</h2>
    
    {% set levels = [
        {'name': 'beginner', 'label': 'Débutant', 'icon': 'star-fill', 'color': 'success', 'courses': beginnerCourses},
        {'name': 'intermediate', 'label': 'Intermédiaire', 'icon': 'star-half', 'color': 'warning', 'courses': intermediateCourses},
        {'name': 'advanced', 'label': 'Avancé', 'icon': 'gem', 'color': 'danger', 'courses': advancedCourses}
    ] %}
    
    {% for level in levels %}
        {% if level.courses|length > 0 %}
        <div class="mb-5">
            <h3 class="mb-4">
                <i class="bi bi-{{ level.icon }} text-{{ level.color }} me-2"></i>
                Niveau {{ level.label }}
                <span class="badge bg-{{ level.color }} ms-2">{{ level.courses|length }} formations</span>
            </h3>
            <div class="row">
                {% for course in level.courses %}
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="course-card">
                        <div class="course-image">
                            {% if course.imageUrl %}
                                <img src="{{ course.imageUrl }}" alt="{{ course.title }}" loading="lazy">
                            {% else %}
                                <i class="bi bi-shield-shaded display-1 text-white-50"></i>
                            {% endif %}
                            <span class="course-badge badge-{{ level.name }}">{{ level.label }}</span>
                        </div>
                        <div class="course-content">
                            <h3 class="course-title">{{ course.title }}</h3>
                            <div class="course-description">
                                {{ course.shortDescription|default(course.description|slice(0, 100)) }}...
                            </div>
                            <div class="course-meta">
                                <span><i class="bi bi-clock"></i> {{ course.duration }} min</span>
                                <span><i class="bi bi-play-circle"></i> {{ course.modules|length }} modules</span>
                            </div>
                            <div class="course-price">
                                {{ (course.price / 100)|number_format(0, ',', ' ') }} MAD
                            </div>
                            <a href="{{ path('app_course_show', {'slug': course.slug}) }}" class="btn-cyber w-100 text-center d-block">
                                📖 Voir les détails
                            </a>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}
    {% endfor %}
</div>

<div id="extraits" class="bg-light py-5">
    <div class="container">
        <h2 class="text-center mb-5" data-aos="fade-up">🎬 Extraits gratuits</h2>
        <div class="row">
            <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="100">
                <div class="video-placeholder" 
                     data-video-id="dQw4w9WgXcQ" 
                     data-platform="youtube"
                     data-video-title="Pourquoi vos mots de passe sont faibles ?">
                    <img src="https://img.youtube.com/vi/dQw4w9WgXcQ/hqdefault.jpg" 
                         alt="Miniature vidéo" 
                         style="width: 100%;">
                    <div class="video-play-btn">
                        <i class="bi bi-play-fill"></i>
                    </div>
                    <div class="p-3 bg-white">
                        <h5>Pourquoi vos mots de passe sont faibles ?</h5>
                        <p class="text-muted small">Extrait de 12 min</p>
                    </div>
                </div>
            </div>
            
            <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="200">
                <div class="video-placeholder" 
                     data-video-id="dQw4w9WgXcQ" 
                     data-platform="youtube"
                     data-video-title="Le phishing expliqué">
                    <img src="https://img.youtube.com/vi/dQw4w9WgXcQ/hqdefault.jpg" 
                         alt="Miniature vidéo" 
                         style="width: 100%;">
                    <div class="video-play-btn">
                        <i class="bi bi-play-fill"></i>
                    </div>
                    <div class="p-3 bg-white">
                        <h5>Le phishing expliqué simplement</h5>
                        <p class="text-muted small">Extrait de 15 min</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
{% extends 'base.html.twig' %}

{% block title %}Mon compte - Cyber Formation Maroc{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm rounded-4">
                <div class="card-body text-center p-4">
                    <i class="bi bi-person-circle display-1 text-primary"></i>
                    <h3 class="mt-3">{{ user.fullName|default(user.email) }}</h3>
                    <p class="text-muted">{{ user.email }}</p>
                    <hr>
                    <a href="{{ path('app_profile_edit') }}" class="btn-cyber-outline w-100">
                        <i class="bi bi-pencil me-2"></i>Modifier mon profil
                    </a>
                </div>
            </div>
        </div>
        
        <div class="col-md-8">
            <div class="card shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h3 class="mb-4">
                        <i class="bi bi-book me-2" style="color: #FF7F00;"></i>
                        Mes formations
                    </h3>
                    
                    {% if enrollments|length > 0 %}
                        {% for enrollment in enrollments %}
                            <div class="border rounded-3 p-3 mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h5 class="mb-0">{{ enrollment.course.title }}</h5>
                                    <span class="badge bg-secondary">Niveau {{ enrollment.course.level|trans }}</span>
                                </div>
                                <div class="progress-cyber mb-2">
                                    <div class="progress-cyber-bar" style="width: {{ enrollment.progress }}%"></div>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-muted">
                                        Inscrit le {{ enrollment.enrolledAt|date('d/m/Y') }}
                                    </small>
                                    <small class="text-primary fw-semibold">{{ enrollment.progress }}% complété</small>
                                </div>
                                <div class="mt-3">
                                    <a href="{{ path('app_course_learn', {slug: enrollment.course.slug}) }}" class="btn-cyber btn-sm">
                                        <i class="bi bi-play-circle me-1"></i>Continuer
                                    </a>
                                </div>
                            </div>
                        {% endfor %}
                        
                        <div class="mt-3 text-center">
                            <a href="{{ path('app_my_courses') }}" class="btn-cyber-outline">
                                Voir toutes mes formations →
                            </a>
                        </div>
                    {% else %}
                        <div class="text-center py-4">
                            <i class="bi bi-inbox display-1 text-muted"></i>
                            <p class="mt-3">Vous n'êtes inscrit à aucune formation.</p>
                            <a href="{{ path('app_course_index') }}" class="btn-cyber">
                                Découvrir nos formations
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
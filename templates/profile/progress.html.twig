{% extends 'base.html.twig' %}

{% block title %}Ma progression - Cyber Formation Maroc{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="mb-4">Ma progression</h1>
    
    <div class="row mb-5">
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h3>{{ stats.total }}</h3>
                    <p class="text-muted">Formations</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h3>{{ stats.completed }}</h3>
                    <p class="text-muted">Terminées</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h3>{{ stats.inProgress }}</h3>
                    <p class="text-muted">En cours</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h3>{{ stats.notStarted }}</h3>
                    <p class="text-muted">Non commencées</p>
                </div>
            </div>
        </div>
    </div>
    
    <div class="card shadow-sm rounded-4">
        <div class="card-body">
            <h3>Détail des formations</h3>
            {% for enrollment in enrollments %}
                <div class="mb-3">
                    <h5>{{ enrollment.course.title }}</h5>
                    <div class="progress-cyber">
                        <div class="progress-cyber-bar" style="width: {{ enrollment.progress }}%"></div>
                    </div>
                    <small class="text-muted">{{ enrollment.progress }}% complété</small>
                </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}